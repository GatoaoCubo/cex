      "args": ["mcp-server-fetch", "--ignore-robots-txt"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "fc-4d0c587df3c44038bbf9f39e175fffd0"
      }
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "d97b2cc5-ce40-4409-94ab-898ed05ca7a8"
      }
    },
    "google-search": {
      "command": "npx",
      "args": ["-y", "serper-search-mcp"],
      "env": {
        "SERPER_API_KEY": "0a673b2e955a91f677fbee43f9c716ecdd315c25"
      }
    },
    "markitdown": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "markitdown-mcp"]
