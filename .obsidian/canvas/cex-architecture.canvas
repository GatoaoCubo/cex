    {
      "id": "n00",
      "type": "text",
      "x": 130, "y": -100, "width": 200, "height": 120,
      "color": "0",
      "text": "## N00 Genesis\n**Pre-sin archetype**\n293 kinds / 298 builders\n*The DNA template*"
    },

    {
      "id": "sep1",
      "type": "text",
      "x": -520, "y": 60, "width": 980, "height": 30,
      "color": "0",
      "text": "### 8F Pipeline --- every nucleus, every task, no exceptions"
    },

    {
      "id": "f1",
      "type": "text",
      "x": -520, "y": 110, "width": 110, "height": 80,
      "color": "4",
      "text": "**F1**\nCONSTRAIN\n`kind+schema`"
    },
    {
      "id": "f2",
      "type": "text",
      "x": -390, "y": 110, "width": 110, "height": 80,
      "color": "4",
      "text": "**F2**\nBECOME\n`load builder`"
    },
    {
      "id": "f3",
      "type": "text",
      "x": -260, "y": 110, "width": 110, "height": 80,
      "color": "4",
      "text": "**F3**\nINJECT\n`context`"
    },
    {
      "id": "f4",
      "type": "text",
      "x": -130, "y": 110, "width": 110, "height": 80,
      "color": "5",
      "text": "**F4**\nREASON\n`plan`"
    },
    {
      "id": "f5",
      "type": "text",
      "x": 0, "y": 110, "width": 110, "height": 80,
      "color": "5",
      "text": "**F5**\nCALL\n`tools+RAG`"
    },
    {
      "id": "f6",
      "type": "text",
      "x": 130, "y": 110, "width": 110, "height": 80,
      "color": "6",
      "text": "**F6**\nPRODUCE\n`generate`"
    },
    {
      "id": "f7",
      "type": "text",
      "x": 260, "y": 110, "width": 110, "height": 80,
      "color": "1",
      "text": "**F7**\nGOVERN\n`quality gate`"
    },
    {
      "id": "f8",
      "type": "text",
      "x": 390, "y": 110, "width": 110, "height": 80,
      "color": "0",
      "text": "**F8**\nCOLLAB\n`save+signal`"
    },

