#!/usr/bin/env bash
# CEX pre-commit hook — runs governance checks before commit.
# Install: git config core.hooksPath .githooks
# Max execution: 5s (timeout enforced)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
TIMEOUT_CMD=""
if command -v timeout &>/dev/null; then
    TIMEOUT_CMD="timeout 5"
fi

# -- 1. Run cex_doctor.py (full repo health) ---------------------------------
echo "[pre-commit] Running cex_doctor.py..."
if ! $TIMEOUT_CMD python "$REPO_ROOT/_tools/cex_doctor.py" 2>&1; then
    echo "[pre-commit] BLOCKED: cex_doctor.py found errors. Fix before commit."
    exit 1
fi

# -- 2. Validate changed builders only ---------------------------------------
CHANGED_BUILDERS=$(git diff --cached --name-only | grep "^archetypes/builders/" | cut -d/ -f3 | sort -u)

if [ -n "$CHANGED_BUILDERS" ]; then
    echo "[pre-commit] Validating changed builders..."
    FAIL=0
    for builder in $CHANGED_BUILDERS; do
        BUILDER_DIR="$REPO_ROOT/archetypes/builders/$builder"
        if [ -d "$BUILDER_DIR" ]; then
            if ! $TIMEOUT_CMD python "$REPO_ROOT/_tools/validate_builder.py" "$BUILDER_DIR" --summary 2>&1; then
                FAIL=1
            fi
        fi
    done
    if [ "$FAIL" -ne 0 ]; then
        echo "[pre-commit] BLOCKED: builder validation failed. Fix before commit."
        exit 1
    fi
fi

# -- 3. Check naming convention on staged .md files --------------------------
BAD_NAMES=$(git diff --cached --name-only | grep "^archetypes/builders/.*\.md$" | while read -r f; do
    fname="$(basename "$f")"
    # Skip README.md and bld_norms.md (repo-level docs)
    case "$fname" in
        README.md|bld_norms.md) continue ;;
    esac
    # Must match bld_{kind}_{topic}.md
    if ! echo "$fname" | grep -qE '^bld_[a-z][a-z0-9_]+_[a-z][a-z0-9_]+\.md$'; then
        echo "  $f (expected bld_{kind}_{topic}.md)"
    fi
done)

if [ -n "$BAD_NAMES" ]; then
    echo "[pre-commit] WARNING: Non-standard file names in builders:"
    echo "$BAD_NAMES"
    # Warning only, not blocking
fi

echo "[pre-commit] All checks passed."
exit 0
