# === CEX .gitignore ===

# Python
__pycache__/
*.pyc

# Secrets
.env
_config/*.credentials
_config/client_secret.json
_config/token.json
**/canva_token.json
**/*_token.json
**/*_credentials.json

# IDE
.obsidian/
.cursorrules
.windsurfrules
.vscode/

# Regenerable
.cex/index.db

# Research artifacts (8.5MB — ephemeral)
_tools/proof/

# Legacy / stale
_archive/
.cex_signals/
_ops/
.githooks/

# Runtime ephemeral
.cex/runtime/
.cex/learning_records/

# Media (not useful for LLM)
_docs/*.mp4
_docs/*.mp3
_docs/*.srt

# Releases (built locally, not tracked)
_releases/

# Platform
Thumbs.db
.DS_Store
nul
.cex/temp/
boot/n01-claude.cmd
