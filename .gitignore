# === CEX .gitignore ===

# Python
__pycache__/
*.pyc

# Secrets
.env
_config/*.credentials
_config/client_secret.json
_config/token.json

# IDE
.obsidian/
.cursorrules
.windsurfrules
.vscode/

# Regenerable
.cex/index.db

# Research artifacts (8.5MB — ephemeral)
_tools/proof/

# Legacy / stale
_archive/
.cex_signals/
_ops/
.githooks/

# Runtime ephemeral
.cex/runtime/

# Media (not useful for LLM)
_docs/*.mp4
_docs/*.mp3
_docs/*.srt

# Platform
Thumbs.db
.DS_Store
