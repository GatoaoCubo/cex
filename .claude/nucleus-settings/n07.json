      "Read", "Write", "Edit", "Bash", "Glob", "Grep", "Agent",
      "mcp__fetch__*",
      "mcp__github__get_*",
      "mcp__github__list_*",
      "mcp__github__search_*",
      "mcp__markitdown__*",
      "mcp__firecrawl__firecrawl_scrape",
      "mcp__firecrawl__firecrawl_search",
      "mcp__firecrawl__firecrawl_map"
