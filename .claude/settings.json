{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "comment": "CEX root settings. Native Claude Code hooks wired into cex_hooks_native.py. Runtime-agnostic: detects CEX_NUCLEUS env. See .claude/rules/new-nucleus-bootstrap.md for per-nucleus overlays.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python _tools/cex_hooks_native.py post-tool-use",
            "timeout": 20
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python _tools/cex_hooks_native.py post-compact",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python _tools/cex_hooks_native.py session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python _tools/cex_hooks_native.py stop",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "comment": "N01-N07 bypass permissions. This allowlist is a template for new Nxx nuclei. See .claude/nucleus-settings/_template.json.",
    "allow": [
      "Bash(python _tools/*:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(ls:*)",
      "Read(**)",
      "Grep(**)",
      "Glob(**)"
    ]
  }
}
