# ============================================================
# CEX Environment Variables
# ============================================================
# Setup:  cp .env.example .env
# Then:   fill only the keys you need (most are optional)
#
# Each key has a direct link to its official creation page.
# Rotate keys regularly. Never commit .env to git.
# ============================================================


# ============================================================
# REQUIRED — At least ONE LLM provider needed to run CEX
# ============================================================

# Anthropic (Claude) — powers all nuclei by default
# Create key: https://console.anthropic.com/settings/keys
# Pricing:    https://docs.anthropic.com/en/docs/about-claude/pricing
ANTHROPIC_API_KEY=


# ============================================================
# OPTIONAL — Additional LLM Providers (fallback chain)
# ============================================================

# OpenAI — GPT fallback for hybrid routing
# Create key: https://platform.openai.com/api-keys
# Pricing:    https://openai.com/api/pricing/
OPENAI_API_KEY=

# Google AI (Gemini) — Gemini runtime + embedding
# Create key: https://aistudio.google.com/apikey
# Pricing:    https://ai.google.dev/pricing
GOOGLE_AI_API_KEY=

# Groq — fast inference (Llama, Mixtral)
# Create key: https://console.groq.com/keys
# Pricing:    https://groq.com/pricing/
GROQ_API_KEY=

# Cerebras — ultra-fast inference
# Create key: https://cloud.cerebras.ai/platform/api-keys
# Pricing:    https://cerebras.ai/pricing
CEREBRAS_API_KEY=

# Nomic — embedding provider (for RAG/retrieval)
# Create key: https://atlas.nomic.ai/data/account
# Pricing:    https://docs.nomic.ai/atlas/models/pricing
NOMIC_API_KEY=


# ============================================================
# OPTIONAL — LiteLLM Proxy (unified multi-provider gateway)
# ============================================================

# LiteLLM — proxy for routing across providers
# Docs:       https://docs.litellm.ai/docs/
# Self-host:  https://docs.litellm.ai/docs/proxy/quick_start
LITELLM_MASTER_KEY=
LITELLM_URL=

# Gemini model override (default: gemini-2.5-pro)
GOOGLE_GEMINI_MODEL=


# ============================================================
# OPTIONAL — Research & Web Tools (N01 Intelligence)
# ============================================================

# Firecrawl — web scraping + structured extraction
# Create key: https://www.firecrawl.dev/app/api-keys
# Pricing:    https://www.firecrawl.dev/pricing
FIRECRAWL_API_KEY=

# Serper — Google search API
# Create key: https://serper.dev/api-key
# Pricing:    https://serper.dev/pricing
SERPER_API_KEY=

# Exa — neural search API
# Create key: https://dashboard.exa.ai/api-keys
# Pricing:    https://exa.ai/pricing
EXA_API_KEY=

# Greptile — codebase search/understanding
# Create key: https://app.greptile.com/settings/api
# Pricing:    https://www.greptile.com/pricing
GREPTILE_API_KEY=

# YouTube Data API — video metadata for research
# Create key: https://console.cloud.google.com/apis/credentials
# Enable API: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=


# ============================================================
# OPTIONAL — Marketing & Content (N02 Marketing)
# ============================================================

# Ayrshare — social media publishing
# Create key: https://app.ayrshare.com/dashboard/api-keys
# Pricing:    https://www.ayrshare.com/pricing
AYRSHARE_API_KEY=

# Google Imagen — AI image generation
# Create key: https://aistudio.google.com/apikey (same as GOOGLE_AI_API_KEY)
# Docs:       https://cloud.google.com/vertex-ai/generative-ai/docs/image/overview
GOOGLE_IMAGEN_API_KEY=
GOOGLE_IMAGEN_MODEL=


# ============================================================
# OPTIONAL — Knowledge & Storage (N04 Knowledge)
# ============================================================

# Google Drive — document ingestion for RAG
# Create OAuth: https://console.cloud.google.com/apis/credentials
# Enable API:   https://console.cloud.google.com/apis/library/drive.googleapis.com
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=


# ============================================================
# OPTIONAL — Infrastructure (N05 Operations)
# ============================================================

# Supabase — database + auth + storage
# Create project: https://supabase.com/dashboard/projects
# Get keys:       https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=

# PostgreSQL — direct database connection
# Format: postgresql://user:pass@host:port/db
DATABASE_URL=

# Railway — deployment platform
# Create token: https://railway.app/account/tokens
# Docs:         https://docs.railway.app/guides/cli
RAILWAY_TOKEN=

# Redis — caching layer
# Format: redis://user:pass@host:port
REDIS_URL=

# GitHub — code operations + MCP server
# Create PAT:  https://github.com/settings/tokens?type=beta
# Scopes:      repo (read), issues (read/write)
GITHUB_TOKEN=
GITHUB_PAT=
GITHUB_PERSONAL_ACCESS_TOKEN=

# E2B — sandboxed code execution
# Create key: https://e2b.dev/dashboard/keys
# Pricing:    https://e2b.dev/pricing
E2B_API_KEY=


# ============================================================
# OPTIONAL — Commerce & Payments (N06 Commercial)
# ============================================================

# Stripe — payment processing
# Create key: https://dashboard.stripe.com/apikeys
# Pricing:    https://stripe.com/pricing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Mercado Pago — LATAM payment processing
# Create key: https://www.mercadopago.com.br/developers/panel/app
# Docs:       https://www.mercadopago.com.br/developers/en/docs
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Shopify — e-commerce platform
# Create key: https://partners.shopify.com/ (then app > API credentials)
# Docs:       https://shopify.dev/docs/api
SHOPIFY_ACCESS_TOKEN=

# Baselinker — multi-channel e-commerce
# Create key: https://panel.baselinker.com/other_api_token.php
# Docs:       https://api.baselinker.com/
BASELINKER_TOKEN=

# Bling — Brazilian ERP
# Create app: https://developer.bling.com.br/aplicativos
# Docs:       https://developer.bling.com.br/
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_TENANT_ID=

# Hotmart — digital products marketplace
# Create key: https://developers.hotmart.com/
# Docs:       https://developers.hotmart.com/docs/en/
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_BASIC_AUTH=


# ============================================================
# OPTIONAL — Notifications (N07 Orchestrator)
# ============================================================

# Discord — webhook notifications
# Create webhook: Server Settings > Integrations > Webhooks
# Docs:           https://discord.com/developers/docs/resources/webhook
DISCORD_WEBHOOK_URL=

# Slack — bot notifications
# Create app:  https://api.slack.com/apps
# Bot token:   https://api.slack.com/authentication/token-types#bot
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_WEBHOOK_URL=


# ============================================================
# OPTIONAL — Media Production (cross-nucleus)
# ============================================================

# ElevenLabs — AI voice synthesis
# Create key: https://elevenlabs.io/app/settings/api-keys
# Pricing:    https://elevenlabs.io/pricing
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=

# Runway — AI video generation
# Create key: https://app.runwayml.com/settings/api-keys
# Pricing:    https://runwayml.com/pricing
RUNWAY_API_KEY=

# Pika — AI video generation
# Create key: https://pika.art/developers
# Pricing:    https://pika.art/pricing
PIKA_API_KEY=

# Kling — AI video generation
# Create key: https://platform.klingai.com/
KLING_API_KEY=

# Hailuo (MiniMax) — AI video generation
# Create key: https://platform.minimaxi.com/
HAILUO_API_KEY=


# ============================================================
# OPTIONAL — Cloud Storage (cross-nucleus)
# ============================================================

# AWS S3 — file storage
# Create key: https://console.aws.amazon.com/iam/home#/security_credentials
# Docs:       https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Cloudflare R2 — S3-compatible storage (no egress fees)
# Create key: https://dash.cloudflare.com/?to=/:account/r2/api-tokens
# Pricing:    https://developers.cloudflare.com/r2/pricing/
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_DOMAIN=


# ============================================================
# OPTIONAL — MCP Servers (Model Context Protocol)
# ============================================================
# These power external tool integrations in .mcp.json / .mcp-n0X.json.
# Leave blank to skip those MCP servers (they auto-disable).

# Canva — design automation
# Create app: https://www.canva.com/developers/
# Docs:       https://www.canva.dev/docs/connect/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# Supabase MCP — database management via MCP
# Create token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_POSTGRES_URL=


# ============================================================
# FREE — No API key needed
# ============================================================
# Ollama: local LLM inference, zero cost, full privacy.
# Install:    https://ollama.ai/download
# Models:     https://ollama.ai/library
# CEX default: ollama pull llama3.1:8b
#
# Fetch MCP:  built-in, no key needed (uvx mcp-server-fetch)
# Markitdown: built-in, no key needed (npx markitdown-mcp-npx)
# GitHub MCP: uses GITHUB_TOKEN above (read-only by default)
