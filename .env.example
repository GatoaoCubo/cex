# =============================================================================
# CEX Environment Variables
# Copy to .env and fill with your keys: cp .env.example .env
# =============================================================================

# --- REQUIRED (at least one for 8F Runner) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here

# --- OPTIONAL (free alternatives exist) ---
# Google AI: used by N01 (research) and N04 (knowledge) via gemini CLI
# If you have Google One subscription, gemini CLI uses OAuth instead (no key needed)
GOOGLE_AI_API_KEY=

# Groq: fast inference alternative
GROQ_API_KEY=

# --- FREE FALLBACK ---
# Ollama runs local models with zero cost. No env var needed.
# Install: https://ollama.ai
# Pull a model: ollama pull qwen2.5-coder:7b
# Boot CEX with: pi -e ./extensions/ollama-provider --model ollama/qwen2.5-coder:7b

# --- NOTES ---
# All core tools (motor, doctor, compile, index) work WITHOUT any API key.
# Only the 8F Runner (F4/F6 LLM calls) requires a provider key or Ollama.
